<Window x:Class="Interlude.Views.IgnoredApplicationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource IgnoreApps.Title}"
        Width="520"
        Height="560"
        MinWidth="500"
        MaxWidth="560"
        MinHeight="460"
        MaxHeight="620"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Loaded="OnLoaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource Brush.AppBackground}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{DynamicResource IgnoreApps.Title}"
                           Style="{StaticResource PageTitleTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource CloseTitleBarButtonStyle}"
                        Click="OnCloseClick"
                        ToolTip="{DynamicResource Common.Close}">
                    <Path Data="M 8 8 L 20 20 M 20 8 L 8 20"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="0,14,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="{DynamicResource IgnoreApps.Search}"
                         Height="34" />
                <WrapPanel Grid.Row="1" Margin="0,8,0,0">
                    <Button Content="{DynamicResource IgnoreApps.Refresh}"
                            Command="{Binding RefreshCommand}" />
                    <Button Content="{DynamicResource IgnoreApps.AddRunning}"
                            Command="{Binding AddRunningAppsCommand}" />
                    <Button Content="{DynamicResource IgnoreApps.AddManual}"
                            Command="{Binding AddManualCommand}"
                            Margin="0" />
                </WrapPanel>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Applications}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.Surface}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32"
                                                Height="32"
                                                CornerRadius="8"
                                                Background="{DynamicResource Brush.SurfaceRaised}"
                                                VerticalAlignment="Center">
                                            <Image Source="{Binding Icon}"
                                                   Width="24"
                                                   Height="24"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Detail}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding IsIgnored}"
                                                  Margin="12,0,0,0"
                                                  VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource PlayerSelection.Cancel}"
                            Command="{Binding CancelCommand}" />
                    <Button Content="{DynamicResource Settings.Save}"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{Binding SaveCommand}"
                            Margin="0" />
                </WrapPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
