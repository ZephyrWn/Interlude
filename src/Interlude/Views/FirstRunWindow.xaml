<Window x:Class="Interlude.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource FirstRun.WindowTitle}"
        Width="500"
        Height="360"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource Brush.AppBackground}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource FirstRun.Title}" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="{DynamicResource FirstRun.Description}"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource CloseTitleBarButtonStyle}"
                        Click="OnCloseClick"
                        ToolTip="{DynamicResource Common.Close}">
                    <Path Data="M 8 8 L 20 20 M 20 8 L 8 20"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round" />
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Style="{StaticResource RoundedCardStyle}"
                    Margin="0,22,0,18">
                <StackPanel>
                    <TextBlock Text="{DynamicResource FirstRun.Step1}" Margin="0,0,0,10" />
                    <TextBlock Text="{DynamicResource FirstRun.Step2}" Margin="0,0,0,10" />
                    <TextBlock Text="{DynamicResource FirstRun.Step3}" Margin="0,0,0,10" />
                    <TextBlock Text="{DynamicResource FirstRun.Later}" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource FirstRun.ChoosePlayer}"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{Binding SelectPlayerCommand}"
                        Margin="0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
