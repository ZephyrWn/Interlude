<Window x:Class="Interlude.Views.LanguageSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Choose language / 选择语言"
        Width="460"
        Height="280"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource Brush.AppBackground}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Choose your language" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="选择你的语言"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource CloseTitleBarButtonStyle}"
                        Click="OnCloseClick"
                        ToolTip="{DynamicResource Common.Close}">
                    <Path Data="M 8 8 L 20 20 M 20 8 L 8 20"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round" />
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Style="{StaticResource RoundedCardStyle}"
                    Margin="0,22,0,18">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Interlude will use this language for setup and settings."
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="Interlude 将使用该语言显示初始设置和后续界面。"
                               Style="{StaticResource MutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="中文" Width="112" Click="OnChineseClick" />
                <Button Content="English" Width="112" Click="OnEnglishClick" Margin="0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
