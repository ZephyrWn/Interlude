<Window x:Class="Interlude.Views.PlayerSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{DynamicResource PlayerSelection.WindowTitle}"
        Width="520"
        SizeToContent="Height"
        MinWidth="500"
        MaxHeight="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Loaded="OnLoaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource Brush.AppBackground}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource PlayerSelection.WindowTitle}"
                               Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="{DynamicResource PlayerSelection.Prompt}"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Style="{StaticResource CloseTitleBarButtonStyle}"
                        Click="OnCloseClick"
                        ToolTip="{DynamicResource Common.Close}">
                    <Path Data="M 8 8 L 20 20 M 20 8 L 8 20"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="0,16,0,14">
                <ListBox ItemsSource="{Binding MediaSessions}"
                         SelectedItem="{Binding SelectedMediaSession, Mode=TwoWay}"
                         MaxHeight="330"
                         Visibility="{Binding HasMediaSessions, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                        <Border x:Name="Card"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12"
                                                MinHeight="68">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource Brush.SurfaceHover}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource Brush.AccentSoft}" />
                                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="34"
                                        Height="34"
                                        CornerRadius="9"
                                        Background="{DynamicResource Brush.AccentSoft}"
                                        VerticalAlignment="Center">
                                    <Path Data="M 8 18 V 7 L 21 5 V 16 M 8 11 L 21 9 M 8 18 A 3 3 0 1 1 2 18 A 3 3 0 0 1 8 18 M 21 16 A 3 3 0 1 1 15 16 A 3 3 0 0 1 21 16"
                                          Stroke="{DynamicResource Brush.Accent}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Stretch="Uniform"
                                          Width="20"
                                          Height="20" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="{DynamicResource Brush.SurfaceRaised}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8,4"
                                            Margin="12,0,10,0">
                                        <TextBlock Text="{Binding PlaybackState, Converter={StaticResource LocalizedEnumConverter}}"
                                                   Style="{StaticResource LabelTextStyle}" />
                                    </Border>
                                    <RadioButton IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Mode=TwoWay}"
                                                 VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Visibility="{Binding HasNoMediaSessions, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="18"
                        MinHeight="120">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource PlayerSelection.EmptyTitle}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{DynamicResource PlayerSelection.EmptyHint}"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <DockPanel Grid.Row="2">
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource PlayerSelection.Refresh}"
                            Command="{Binding RefreshCommand}" />
                    <Button Content="{DynamicResource PlayerSelection.Cancel}"
                            IsCancel="True" />
                    <Button Content="{DynamicResource PlayerSelection.SetAsDefault}"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{Binding SetAsDefaultCommand}"
                            Margin="0" />
                </WrapPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
