<Window x:Class="Interlude.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="间奏 | Interlude"
        Icon="/Assets/interlude.ico"
        Width="520"
        Height="360"
        MinWidth="520"
        MinHeight="360"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="InfoTileStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MinHeight" Value="70" />
        </Style>

        <Style x:Key="TileIconStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DividerStyle" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="0,10,0,10" />
            <Setter Property="Background" Value="{DynamicResource Brush.Border}" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource Brush.AppBackground}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,6,0,2">
                    <Image Source="/Assets/interlude-logo.png"
                           Width="28"
                           Height="28"
                           Margin="0,0,10,0"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="间奏 | Interlude" FontSize="16" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,6,8,2">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="OnMinimizeClick"
                            ToolTip="{DynamicResource Common.Minimize}">
                        <Path Data="M 8 15 H 20"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round" />
                    </Button>
                    <Button Style="{StaticResource CloseTitleBarButtonStyle}"
                            Click="OnCloseClick"
                            ToolTip="{DynamicResource Common.Close}">
                        <Path Data="M 8 8 L 20 20 M 20 8 L 8 20"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round" />
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="14,6,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="4"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ToggleButton Grid.Column="0"
                                      Style="{StaticResource SidebarToggleButtonStyle}"
                                      IsChecked="{Binding IsStatusPageSelected, Mode=OneWay}"
                                      Command="{Binding ShowStatusPageCommand}"
                                      Margin="0,0,6,0">
                            <TextBlock Text="{DynamicResource Main.Status}"
                                       HorizontalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        </ToggleButton>
                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource SidebarToggleButtonStyle}"
                                      IsChecked="{Binding IsSettingsPageSelected, Mode=OneWay}"
                                      Command="{Binding ShowSettingsPageCommand}"
                                      Margin="0">
                            <TextBlock Text="{DynamicResource Main.Settings}"
                                       HorizontalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        </ToggleButton>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12">
                    <Grid>
                        <Grid Visibility="{Binding IsStatusPageSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top">
                                    <ToggleButton Style="{StaticResource ShellToggleButtonStyle}"
                                                  IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                  Command="{Binding ToggleAutomationCommand}"
                                                  Margin="0,0,8,0">
                                        <TextBlock Text="{Binding AutomationToggleText}"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                                    </ToggleButton>

                                    <Button Command="{Binding ImmediateRestoreCommand}" Margin="0">
                                        <TextBlock Text="{DynamicResource Main.RestoreMusicNow}"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </Button>
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Main.RunningStatus}" Style="{StaticResource PageTitleTextStyle}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <Ellipse Width="9" Height="9" Fill="{DynamicResource Brush.StatusOk}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding IsEnabledText}" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>

                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource InfoTileStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="46" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource TileIconStyle}" Background="{DynamicResource Brush.IconBlueBackground}">
                                            <Path Data="M 5 7 H 23 V 19 H 5 Z M 12 23 H 16 M 14 19 V 23"
                                                  Stroke="{DynamicResource Brush.IconBlue}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"
                                                  Width="23"
                                                  Height="23" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource Main.CurrentPlayer}" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding TargetPlayer}" Style="{StaticResource ValueTextStyle}" Margin="0,4,0,0" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Style="{StaticResource IconButtonStyle}"
                                                Command="{Binding ChangePlayerCommand}"
                                                ToolTip="{DynamicResource Main.ChangePlayer}">
                                            <Path Data="M 17 3 L 21 7 L 17 11 M 3 7 H 21 M 7 13 L 3 17 L 7 21 M 3 17 H 21"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"
                                                  Width="14"
                                                  Height="14" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource InfoTileStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="46" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource TileIconStyle}" Background="{DynamicResource Brush.IconGreenBackground}">
                                            <Path Data="M 10 7 L 20 14 L 10 21 Z M 14 3 A 11 11 0 1 1 13.9 3"
                                                  Stroke="{DynamicResource Brush.IconGreen}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"
                                                  Width="24"
                                                  Height="24" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource Main.PlaybackState}" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding PlaybackStateText}" Style="{StaticResource ValueTextStyle}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Style="{StaticResource InfoTileStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="46" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource TileIconStyle}" Background="{DynamicResource Brush.IconPurpleBackground}">
                                            <Path Data="M 12 3 L 20 7 V 12 C 20 17 16.5 20.5 12 22 C 7.5 20.5 4 17 4 12 V 7 Z M 9 12 L 11.2 14.2 L 15.5 9.8"
                                                  Stroke="{DynamicResource Brush.IconPurple}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"
                                                  Width="24"
                                                  Height="24" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource Main.TargetAvailability}" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding TargetAvailability}" Style="{StaticResource ValueTextStyle}" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource InfoTileStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource TileIconStyle}" Background="{DynamicResource Brush.IconOrangeBackground}">
                                            <Path Data="M 5 6 H 19 V 18 H 5 Z M 8 10 L 11 12 L 8 14 M 13 15 H 17"
                                                  Stroke="{DynamicResource Brush.IconOrange}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"
                                                  Width="24"
                                                  Height="24" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource Main.DetectionMode}" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding DetectionModeText}" Style="{StaticResource ValueTextStyle}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding IgnoredApplicationsSummary}"
                                                       Style="{StaticResource LabelTextStyle}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Visibility="{Binding IsSettingsPageSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{DynamicResource Main.Settings}" Style="{StaticResource PageTitleTextStyle}" />

                            <ScrollViewer Grid.Row="1" Margin="0,10,0,10" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource Main.GeneralSettings}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{DynamicResource Settings.Language}" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding LanguageOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Left"
                                                  Width="180" />

                                        <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                            <CheckBox Content="{DynamicResource Settings.StartWithWindows}" IsChecked="{Binding Settings.StartWithWindows}" Width="210" />
                                            <CheckBox Content="{DynamicResource Settings.StartMinimizedToTray}" IsChecked="{Binding Settings.MinimizeToTray}" Width="210" />
                                            <CheckBox Content="{DynamicResource Settings.CloseWindowToTray}" IsChecked="{Binding Settings.CloseToTray}" Width="210" />
                                            <CheckBox Content="{DynamicResource Settings.RespectManualPlaybackChanges}" IsChecked="{Binding Settings.RespectManualOverride}" Width="210" />
                                        </WrapPanel>
                                    </Grid>

                                    <Border Style="{StaticResource DividerStyle}" />

                                    <TextBlock Text="{DynamicResource Main.PlayerSettings}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{DynamicResource Settings.CurrentDefaultPlayer}" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" />
                                        <DockPanel Grid.Column="1" LastChildFill="True">
                                            <Button DockPanel.Dock="Right"
                                                    Style="{StaticResource IconButtonStyle}"
                                                    Command="{Binding ChangePlayerCommand}"
                                                    ToolTip="{DynamicResource Main.ChangePlayer}">
                                                <Path Data="M 17 3 L 21 7 L 17 11 M 3 7 H 21 M 7 13 L 3 17 L 7 21 M 3 17 H 21"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Stretch="Uniform"
                                                      Width="14"
                                                      Height="14" />
                                            </Button>
                                            <TextBlock Text="{Binding TargetPlayer}" Style="{StaticResource ValueTextStyle}" VerticalAlignment="Center" />
                                        </DockPanel>

                                    </Grid>

                                    <Border Style="{StaticResource DividerStyle}" />

                                    <TextBlock Text="{DynamicResource Main.DetectionSettings}" Style="{StaticResource SectionTitleTextStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="86" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="108" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="{DynamicResource Settings.Mode}" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1"
                                                  Grid.ColumnSpan="4"
                                                  ItemsSource="{Binding DetectionModeOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding Settings.Detection.Mode, Mode=TwoWay}"
                                                  Width="180"
                                                  HorizontalAlignment="Left" />

                                        <TextBlock Grid.Row="1" Text="{DynamicResource IgnoreApps.EntryTitle}" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" />
                                        <DockPanel Grid.Row="1"
                                                   Grid.Column="1"
                                                   Grid.ColumnSpan="4"
                                                   LastChildFill="False">
                                            <Button DockPanel.Dock="Right"
                                                    Content="{DynamicResource IgnoreApps.Manage}"
                                                    Command="{Binding OpenIgnoredApplicationsCommand}"
                                                    Margin="12,0,14,0" />
                                            <TextBlock Text="{Binding IgnoredApplicationsSummary}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       VerticalAlignment="Center" />
                                        </DockPanel>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Grid.ColumnSpan="4"
                                                   Text="{DynamicResource IgnoreApps.Description}"
                                                   Style="{StaticResource LabelTextStyle}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,8" />

                                        <TextBlock Grid.Row="3" Text="{DynamicResource Settings.ActivityThreshold}" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" />
                                        <TextBox Grid.Row="3" Grid.Column="1" Width="82" HorizontalAlignment="Left" Text="{Binding Settings.Detection.StartThreshold, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="3" Grid.Column="3" Text="{DynamicResource Settings.PollIntervalMs}" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" />
                                        <TextBox Grid.Row="3" Grid.Column="4" Width="58" HorizontalAlignment="Left" Margin="0,0,0,8" Text="{Binding Settings.Detection.PollIntervalMs, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="4" Text="{DynamicResource Settings.ResumeDelayMs}" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" />
                                        <TextBox Grid.Row="4" Grid.Column="1" Width="82" HorizontalAlignment="Left" Text="{Binding Settings.Detection.ResumeDelayMs, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Grid.Row="4"
                                                  Grid.Column="3"
                                                  Grid.ColumnSpan="2"
                                                  Content="{DynamicResource Settings.IgnoreSystemSounds}"
                                                  IsChecked="{Binding Settings.Detection.IgnoreSystemSounds}" />
                                    </Grid>

                                    <Border Style="{StaticResource DividerStyle}" />

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="{DynamicResource Main.Logs}" Style="{StaticResource SectionTitleTextStyle}" />

                                        <Border Grid.Row="1"
                                                Style="{StaticResource PanelBorderStyle}"
                                                Padding="14"
                                                Margin="0,18,0,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{DynamicResource Main.LogDirectory}" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding LogDirectory}"
                                                           Style="{StaticResource ValueTextStyle}"
                                                           Margin="0,8,0,14" />
                                                <Button Grid.Row="2"
                                                        Content="{DynamicResource Settings.OpenLogDirectory}"
                                                        Command="{Binding OpenLogsCommand}"
                                                        HorizontalAlignment="Left"
                                                        Margin="0" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Border Style="{StaticResource DividerStyle}" />

                                    <StackPanel>
                                        <TextBlock Text="About / Interlude"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextSecondary}"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                                   Margin="0,0,0,6">
                                            <Hyperlink NavigateUri="https://github.com/ZephyrWn/Interlude"
                                                       RequestNavigate="OnGitHubLinkRequestNavigate"
                                                       Foreground="{DynamicResource Brush.TextSecondary}"
                                                       TextDecorations="{x:Null}"
                                                       Cursor="Hand">
                                                <InlineUIContainer BaselineAlignment="Center">
                                                    <Path Data="M 12 2 C 6.48 2 2 6.59 2 12.25 C 2 16.78 4.87 20.62 8.84 21.98 C 9.34 22.08 9.52 21.76 9.52 21.49 C 9.52 21.25 9.51 20.63 9.51 19.8 C 6.73 20.42 6.14 18.43 6.14 18.43 C 5.68 17.24 5.03 16.92 5.03 16.92 C 4.12 16.28 5.1 16.29 5.1 16.29 C 6.1 16.36 6.63 17.35 6.63 17.35 C 7.52 18.91 8.97 18.46 9.54 18.2 C 9.63 17.54 9.89 17.09 10.17 16.84 C 7.95 16.58 5.62 15.7 5.62 11.76 C 5.62 10.64 6.01 9.72 6.65 9.01 C 6.55 8.75 6.2 7.7 6.75 6.29 C 6.75 6.29 7.59 6.01 9.5 7.34 C 10.3 7.11 11.15 7 12 7 C 12.85 7 13.7 7.11 14.5 7.34 C 16.41 6.01 17.25 6.29 17.25 6.29 C 17.8 7.7 17.45 8.75 17.35 9.01 C 17.99 9.72 18.38 10.64 18.38 11.76 C 18.38 15.71 16.04 16.58 13.81 16.83 C 14.17 17.15 14.49 17.77 14.49 18.73 C 14.49 20.1 14.48 21.2 14.48 21.49 C 14.48 21.76 14.66 22.09 15.17 21.98 C 19.13 20.62 22 16.78 22 12.25 C 22 6.59 17.52 2 12 2 Z"
                                                          Fill="{DynamicResource Brush.TextSecondary}"
                                                          Width="14"
                                                          Height="14"
                                                          Stretch="Uniform"
                                                          Margin="0,0,6,0" />
                                                </InlineUIContainer>
                                                <Run Text="GitHub: https://github.com/ZephyrWn/Interlude" />
                                            </Hyperlink>
                                        </TextBlock>
                                        <TextBlock Text="Version: v0.8.0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
                                <Button Content="{DynamicResource Settings.Reset}" Command="{Binding ResetSettingsCommand}" />
                                <Button Content="{DynamicResource Settings.Save}" Style="{StaticResource AccentButtonStyle}" Command="{Binding SaveSettingsCommand}" Margin="0" />
                            </WrapPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
